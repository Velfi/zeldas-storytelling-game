	step=story_runtime_advance(&proof_runtime);step=story_runtime_advance(&proof_runtime);step=story_runtime_choose(&proof_runtime,"memory_second_choice.choice.1");assert(step.ok&&step.node_id=="ada_calls_thomas")
	step=story_runtime_advance(&proof_runtime);_=story_runtime_advance(&proof_runtime)
