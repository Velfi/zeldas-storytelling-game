E)+1),reverse_view.eye.z-reverse_forward.y*(math.abs(CITY_DRIVING_BEHIND_DISTANCE)+1)};assert(city_render_chunk_visible(&cull_game,reverse_ahead.x,reverse_ahead.y,CITY_BUILDING_DRAW_DISTANCE,CITY_DRIVING_BEHIND_DISTANCE));assert(!city_render_chunk_visible(&cull_game,reverse_behind.x,reverse_behind.y,CITY_BUILDING_DRAW_DISTANCE,CITY_DRIVING_BEHIND_DISTANCE))
