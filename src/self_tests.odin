	step=story_runtime_advance(&proof_runtime);_=story_runtime_advance(&proof_runtime)
	step=story_runtime_enter_scene(&proof_runtime,"ada_release");step=story_runtime_advance(&proof_runtime);step=story_runtime_choose(&proof_runtime,"player_final_choice.choice.0");assert(step.ok&&step.node_id=="player_releases_ghosts")
	step=story_runtime_advance(&proof_runtime);_=story_runtime_advance(&proof_runtime)
	assert(proof_runtime.state.objectives[story_state_objective_index(&proof_runtime.state,"help_ada")].status==.Completed)
