	append(&project.invariants,Story_Invariant{id="trust_bounded",description="Trust remains within its declared bounds.",kind=.Always,condition_root=0,required=true})

	validation:=story_project_validate(&project);assert(validation.ok&&validation.error_count==0);story_validation_destroy(&validation)
	parsed_status,parsed_ok:=story_objective_status_from_text("");assert(parsed_ok&&parsed_status==.Inactive);_,parsed_ok=story_objective_status_from_text("typo");assert(!parsed_ok)
