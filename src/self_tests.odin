	milestone_state:=story_state_new(&project);milestone_game:=Game{story_project=&project,story_state=&milestone_state};assert(game_story_milestone(&milestone_game,"test.objective_milestone")&&milestone_state.objectives[0].status==.Completed&&milestone_state.objectives[1].status==.Active);story_state_destroy(&milestone_state)
